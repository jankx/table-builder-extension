{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "jankx/master-table",
  "title": "Master Table",
  "category": "jankx",
  "icon": "table",
  "description": "A customizable table with advanced styling options",
  "keywords": ["table", "data", "grid", "master"],
  "textdomain": "jankx",
  "attributes": {
    "hasFixedLayout": {
      "type": "boolean",
      "default": false
    },
    "hasHeaderRow": {
      "type": "boolean",
      "default": true
    },
    "hasFooterRow": {
      "type": "boolean",
      "default": false
    }
  },
  "supports": {
    "html": false,
    "align": ["wide", "full"],
    "spacing": {
      "margin": true,
      "padding": true
    },
    "color": {
      "background": true,
      "text": true
    },
    "__experimentalBorder": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true,
      "__experimentalDefaultControls": {
        "color": true,
        "radius": true,
        "style": true,
        "width": true
      }
    },
    "typography": {
      "fontSize": true,
      "lineHeight": true
    }
  },
  "editorScript": "file:./build/index.js",
  "editorStyle": "file:./build/editor.css",
  "style": "file:./build/style.css"
}

