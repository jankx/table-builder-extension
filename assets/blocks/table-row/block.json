{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "jankx/table-row",
  "title": "Table Row",
  "category": "jankx",
  "parent": ["jankx/master-table"],
  "icon": "table-row-before",
  "description": "A table row with customizable cells",
  "keywords": ["table", "row", "tr"],
  "textdomain": "jankx",
  "attributes": {
    "isHeader": {
      "type": "boolean",
      "default": false
    },
    "isFooter": {
      "type": "boolean",
      "default": false
    }
  },
  "supports": {
    "html": false,
    "reusable": false,
    "spacing": {
      "padding": true
    },
    "color": {
      "background": true,
      "text": true
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true,
      "__experimentalDefaultControls": {
        "color": true,
        "style": true,
        "width": true
      }
    }
  },
  "editorScript": "file:./build/index.js",
  "editorStyle": "file:./build/editor.css",
  "style": "file:./build/style.css"
}

